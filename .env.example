# Supabase — get these from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER prefix with NEXT_PUBLIC_. Used for admin/rate-limit ops.
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_PROJECT_ID=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Captcha (Cloudflare Turnstile recommended — free, no phone verification)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Rate limiting (Upstash Redis — free tier works for thousands of users)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Random long string, used to salt the one-way sender fingerprint hash
FINGERPRINT_SALT=
